# Copy to .env and fill in values before starting the server.
# Every Rust node in the cluster MUST share the same JWT_SECRET so that
# a token signed by node A can be verified by node B.

REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_SECONDS=86400
BIND_ADDR=0.0.0.0:3000
STATIC_DIR=../client-lite/build

# PostgreSQL — optional. If unset the relay starts without a DB.
# When set, migrations are applied automatically on startup.
# Run migrations manually: sqlx migrate run --database-url "$DATABASE_URL"
DATABASE_URL=postgres://user:password@localhost/audioserver

# First-run bootstrap — create the initial admin account.
# Both must be set and admin_users table must be empty for this to take effect.
# REMOVE THESE FROM ENV after the first successful boot.
# BOOTSTRAP_USERNAME=admin
# BOOTSTRAP_PASSWORD=change-me-strong-password
